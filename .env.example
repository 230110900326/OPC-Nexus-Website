# Public web application
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Server-only URL used by Next.js metadata and sitemap generation in Docker.
API_INTERNAL_URL=http://localhost:4000

# NestJS API
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET=replace-with-a-local-32-character-minimum-access-secret
JWT_REFRESH_SECRET=replace-with-a-local-32-character-minimum-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Keep false for local HTTP; set true when the browser-facing API uses HTTPS.
COOKIE_SECURE=false
REFRESH_COOKIE_PATH=/auth

# Image storage: local or s3
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=auto
# S3_BUCKET=opc-assets
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://cdn.example.com

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opc_nexus
DB_USER=opc
DB_PASSWORD=change-me-locally

# FastAPI crawler service
CRAWLER_HOST=0.0.0.0
CRAWLER_PORT=8000
CRAWLER_LOG_LEVEL=INFO
CRAWLER_REDIS_URL=redis://localhost:6379/0
CRAWLER_REQUEST_TIMEOUT_SECONDS=10
CRAWLER_ALLOWED_DOMAINS=127.0.0.1,localhost
CRAWLER_LOCAL_TEST_PAGE_URL=http://127.0.0.1:8099/article.html
CRAWLER_SCHEDULER_ENABLED=false
CRAWLER_SCHEDULE_HOUR=7
CRAWLER_SCHEDULE_MINUTE=30
CRAWLER_TIMEZONE=Asia/Shanghai
CRAWLER_MAX_ITEMS_PER_SOURCE=25
CRAWLER_API_URL=http://localhost:4000
# Set one shared random value of at least 32 characters for API ↔ crawler calls.
CRAWLER_API_TOKEN=replace-with-a-local-32-character-minimum-crawler-token
CRAWLER_SERVICE_URL=http://localhost:8000
# Built-in znt news intelligence. Rules run locally by default.
CRAWLER_INTELLIGENCE_ENABLED=true
CRAWLER_INTELLIGENCE_PROVIDER=none
CRAWLER_INTELLIGENCE_MODEL=
CRAWLER_INTELLIGENCE_BASE_URL=
CRAWLER_INTELLIGENCE_LLM_SCOPE=candidates
# Optional override; the bundled znt/config.json is used when empty.
CRAWLER_INTELLIGENCE_CONFIG_PATH=
# OPENAI_API_KEY=only-needed-when-provider-is-openai

# Local infrastructure — replace locally; never commit real credentials
POSTGRES_DB=opc_nexus
POSTGRES_USER=opc
POSTGRES_PASSWORD=change-me-locally
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---- 邮件发送（SMTP）----
# QQ 邮箱：smtp.qq.com:465   163 邮箱：smtp.163.com:465
# 获取授权码：QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-authorization-code
# SMTP_FROM="OPC Nexus" <your-email@qq.com>

# ---- Production operations (optional) ----
# PUBLIC_HTTP_PORT=80
# BACKUP_DIR=/var/backups/opc-nexus
# BACKUP_RETENTION_DAYS=14
# ALERT_WEBHOOK_URL=https://example.com/your-enterprise-webhook
# DISK_ALERT_PERCENT=85
